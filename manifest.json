{
  "manifest_version": 3,
  "name": "ScratchAI — AI Coder for Scratch",
  "version": "1.0.0",
  "description": "Generate, fix, and explain Scratch code using ChatGPT. Works directly on scratch.mit.edu!",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://scratch.mit.edu/*",
    "https://api.openai.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://scratch.mit.edu/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
